<Window x:Class="HdLabs.Finder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HdLabs.Finder"
        mc:Ignorable="d"
        Title="{Binding Title}" Icon="{StaticResource HdAppIcon}" Height="560" Width="980" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                    <Button Command="{Binding SearchCommand}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Content" Value="Search"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                        <Setter Property="Content" Value="Searching..."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <TextBox Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}" FontSize="16" BorderThickness="0" />
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,12">
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource EzMutedBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                <Button Content="Open" Command="{Binding OpenSelectedCommand}" Margin="0,0,8,0"/>
                <Button Content="Open folder" Command="{Binding OpenSelectedFolderCommand}"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" ItemsSource="{Binding Results}" SelectedItem="{Binding Selected}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding FullPath}" Foreground="{StaticResource EzMutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="1" Text="Tip: for now it scans under your user profile. Next we’ll add indexing for instant search."
                           Foreground="{StaticResource EzMutedBrush}" Margin="6,8,6,4"/>
            </Grid>
        </Border>
    </Grid>
</Window>

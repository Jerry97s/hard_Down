<Window x:Class="HdLabs.Memo.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HdLabs.Memo"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Icon="{StaticResource HdAppIcon}"
        Height="760"
        Width="1040"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- 포레스트 민트 + 웜 페이퍼: 그라데이션으로 깊이만 살짝 -->
        <LinearGradientBrush x:Key="MemoBarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E2F0EA" Offset="0"/>
            <GradientStop Color="#B8D4C8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="MemoBodyBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FEFFFE" Offset="0"/>
            <GradientStop Color="#F2F7F5" Offset="0.55"/>
            <GradientStop Color="#E8F1ED" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="MemoFooterBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#C9E0D6" Offset="0"/>
            <GradientStop Color="#9CBEAE" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="MemoOuterBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D9EDE4" Offset="0"/>
            <GradientStop Color="#9BB5AA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="MemoListHeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D2EBE2" Offset="0"/>
            <GradientStop Color="#B5D8CA" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="MemoSectionDividerBrush" Color="#3A5248"/>
        <SolidColorBrush x:Key="MemoToolbarIconBrush" Color="#2D4A40"/>
        <SolidColorBrush x:Key="MemoTextBrush" Color="#263330"/>
        <SolidColorBrush x:Key="MemoSliderTrackBrush" Color="#6E9084"/>
        <SolidColorBrush x:Key="MemoSliderThumbStrokeBrush" Color="#C5DDD3"/>
        <SolidColorBrush x:Key="MemoHoverWashBrush" Color="#26FFFFFF"/>

        <Style x:Key="MemoIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HoverBg"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBg" Property="Background" Value="{StaticResource MemoHoverWashBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverBg" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MemoFormatTextButton" TargetType="Button" BasedOn="{StaticResource MemoIconButton}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontStyle" Value="Normal"/>
        </Style>

        <Style x:Key="MemoSliderInvisibleRepeat" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 참고: 갈회색 트랙 + 흰 원 썸(얇은 테두리) + 아래쪽 가벼운 그림자 -->
        <Style x:Key="MemoFooterSlider" TargetType="Slider">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="TickPlacement" Value="None"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
            <!-- 트랙 클릭 시 커서 위치로 썸 이동 (기본 LargeChange 점프 방지) -->
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Minimum" Value="0.35"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{StaticResource MemoSliderTrackBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid SnapsToDevicePixels="True" MinHeight="24">
                            <Rectangle Height="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       Margin="12,0,12,0"
                                       Fill="{StaticResource MemoSliderTrackBrush}"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Opacity="0.92"/>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Style="{StaticResource MemoSliderInvisibleRepeat}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Style="{StaticResource MemoSliderInvisibleRepeat}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="24" Height="24">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Width="24" Height="24">
                                                    <Ellipse Width="14"
                                                             Height="14"
                                                             Fill="#FFFFFF"
                                                             Stroke="{StaticResource MemoSliderThumbStrokeBrush}"
                                                             StrokeThickness="0.9"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="4"
                                                                              ShadowDepth="2"
                                                                              Direction="270"
                                                                              Opacity="0.28"
                                                                              Color="#40000000"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 참고 UI 구성: 스티키 카드 하나 = [상단바 | 본문 | 하단 툴바] 세로 스택만 -->
    <Border Padding="24"
            Background="Transparent"
            MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
        <Border x:Name="RootMemoCard"
                CornerRadius="16"
                BorderBrush="{StaticResource MemoOuterBorderBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True"
                ClipToBounds="True"
                Background="{StaticResource MemoBodyBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="36"
                                  ShadowDepth="8"
                                  Direction="270"
                                  Opacity="0.19"
                                  Color="#40000000"/>
            </Border.Effect>

            <Grid>
                <!-- 비율 고정감: 상·하단은 내용 높이, 가운데만 남는 공간 전부 -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══ (1) 상단바: 왼쪽 '+만' · 가운데 빈 여백 · 오른쪽 아이콘 묶음 ═══ -->
                <Border Grid.Row="0"
                        MinHeight="48"
                        Background="{StaticResource MemoBarBrush}"
                        CornerRadius="16,16,0,0"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource MemoIconButton}"
                                ToolTip="새 메모 (Ctrl+N)"
                                Command="{Binding NewCommand}"
                                Padding="8,8">
                            <Viewbox Width="26"
                                     Height="26"
                                     Stretch="Uniform">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="{StaticResource MemoToolbarIconBrush}"
                                           Text="&#xE710;"/>
                            </Viewbox>
                        </Button>

                        <!-- 가운데는 의도적으로 비움 (참고 스크린과 동일) -->

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="더보기"
                                    Padding="8,8"
                                    Click="MoreOptions_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE712;"/>
                                </Viewbox>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="저장" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                                        <Separator/>
                                        <MenuItem Header="메모 편집" Command="{Binding ShowEditorCommand}"/>
                                        <MenuItem Header="메모 목록" Command="{Binding ShowListCommand}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="일정 (캘린더 연동 예정)"
                                    Padding="8,8"
                                    Click="PlaceholderCalendar_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE787;"/>
                                </Viewbox>
                            </Button>

                            <Button Style="{StaticResource MemoIconButton}"
                                    Padding="8,8"
                                    ClipToBounds="False"
                                    ToolTip="알림 (예정)"
                                    Click="PlaceholderAlarm_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <Canvas Width="26"
                                            Height="26"
                                            ClipToBounds="False"
                                            SnapsToDevicePixels="True">
                                        <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 6,7.5 Q 10,2.25 13,7.5"/>
                                        <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 13,7.5 Q 17,2.25 20,7.5"/>
                                        <Ellipse Canvas.Left="5.5"
                                                 Canvas.Top="7.5"
                                                 Width="15"
                                                 Height="15"
                                                 Stroke="{StaticResource MemoToolbarIconBrush}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent"/>
                                        <Line X1="13"
                                              Y1="15"
                                              X2="18.5"
                                              Y2="15"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Line X1="13"
                                              Y1="15"
                                              X2="13"
                                              Y2="9"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Line X1="10.5"
                                              Y1="21.5"
                                              X2="8"
                                              Y2="23.5"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"/>
                                        <Line X1="15.5"
                                              Y1="21.5"
                                              X2="18"
                                              Y2="23.5"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button x:Name="ColorPickerButton"
                                    Style="{StaticResource MemoIconButton}"
                                    ToolTip="메모지 색 (본문 틴트)"
                                    Padding="8,8"
                                    Click="ColorPickerButton_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE790;"/>
                                </Viewbox>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ColorTintMenu">
                                        <MenuItem Click="ColorTintClick" Tag="#E8F1ED" Header="기본 민트"/>
                                        <MenuItem Click="ColorTintClick" Tag="#E8EEF1" Header="아이스 블루"/>
                                        <MenuItem Click="ColorTintClick" Tag="#F0EDE8" Header="웜 페이퍼"/>
                                        <MenuItem Click="ColorTintClick" Tag="#EEF0E6" Header="올리브 미스트"/>
                                        <MenuItem Click="ColorTintClick" Tag="#F1EBF0" Header="소프트 라벤더"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="항상 위"
                                    Padding="8,8"
                                    Command="{Binding TogglePinCommand}">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE718;"/>
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="닫기"
                                    Padding="8,8"
                                    Click="Close_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform"
                                         SnapsToDevicePixels="True">
                                    <Canvas Width="26"
                                            Height="26"
                                            SnapsToDevicePixels="True">
                                        <Line X1="7"
                                              Y1="7"
                                              X2="19"
                                              Y2="19"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1.15"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Line X1="19"
                                              Y1="7"
                                              X2="7"
                                              Y2="19"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1.15"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Row="1"
                           Height="1"
                           VerticalAlignment="Stretch"
                           Fill="{StaticResource MemoSectionDividerBrush}"
                           SnapsToDevicePixels="True"/>

                <!-- ═══ (2) 본문: 한 장의 노트처럼 한 덩어리 입력 영역 ═══ -->
                <Border Grid.Row="2"
                        Background="Transparent">
                    <Grid Margin="22,16,22,16">

                        <!-- 편집: 제목(첫 줄) + 본문 = 시각적으로 한 블록 (참고: 상단 한 줄 제목 느낌) -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditorView}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI"
                                     FontSize="18"
                                     FontWeight="SemiBold"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0,0,0,6"
                                     Foreground="{StaticResource MemoTextBrush}"/>

                            <TextBox x:Name="MemoBody"
                                     Grid.Row="1"
                                     Text="{Binding NewBody, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     FontFamily="Segoe UI"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="15"
                                     Padding="0,2,0,0"
                                     CaretBrush="{StaticResource MemoTextBrush}"
                                     Foreground="{StaticResource MemoTextBrush}"/>
                        </Grid>

                        <!-- 목록: 같은 카드 안에서만 중앙 패널 교체 -->
                        <DockPanel LastChildFill="True">
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsListView}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>

                            <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource MemoTextBrush}"
                                        Padding="12,6"
                                        Background="#33FFFFFF"
                                        BorderBrush="{StaticResource MemoOuterBorderBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Content="열기"
                                        Command="{Binding OpenSelectedCommand}"
                                        Margin="8,0,0,0"/>

                                <TextBlock Text="메모 목록"
                                           FontFamily="Segoe UI"
                                           Foreground="{StaticResource MemoTextBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <ListView x:Name="MemoList"
                                      ItemsSource="{Binding Items}"
                                      SelectedItem="{Binding Selected}"
                                      BorderThickness="1"
                                      BorderBrush="{StaticResource MemoOuterBorderBrush}"
                                      Background="#26FFFFFF"
                                      MouseDoubleClick="MemoList_OnMouseDoubleClick"
                                      KeyDown="MemoList_OnKeyDown">
                                <ListView.ContextMenu>
                                    <ContextMenu DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}">
                                        <MenuItem Header="편집" Command="{Binding OpenSelectedCommand}"/>
                                        <MenuItem Header="삭제" Command="{Binding DeleteSelectedCommand}"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.Resources>
                                    <Style TargetType="GridViewColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource MemoListHeaderBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                    </Style>
                                </ListView.Resources>

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="6,8"/>
                                        <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#55FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="제목" Width="320" DisplayMemberBinding="{Binding Title}"/>
                                        <GridViewColumn Header="생성" Width="150" DisplayMemberBinding="{Binding CreatedDisplay}"/>
                                        <GridViewColumn Header="수정" Width="150" DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                                        <GridViewColumn Header="그룹" Width="120" DisplayMemberBinding="{Binding Group}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Row="3"
                           Height="1"
                           VerticalAlignment="Stretch"
                           Fill="{StaticResource MemoSectionDividerBrush}"
                           SnapsToDevicePixels="True"/>

                <!-- ═══ (3) 하단: 8칸 균등 ═══ -->
                <Border Grid.Row="4"
                        MinHeight="54"
                        CornerRadius="0,0,16,16"
                        Background="{StaticResource MemoFooterBrush}"
                        ClipToBounds="True">
                        <UniformGrid Rows="1"
                                     Columns="8"
                                     Margin="10,8,8,6">
                            <Button Style="{StaticResource MemoFormatTextButton}"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource MemoToolbarIconBrush}"
                                    Content="B"
                                    HorizontalAlignment="Center"
                                    ToolTip="굵게 · 선택에 ** 추가"
                                    Click="FormatBold_Click"/>
                            <Button Style="{StaticResource MemoFormatTextButton}"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource MemoToolbarIconBrush}"
                                    Content="/"
                                    HorizontalAlignment="Center"
                                    ToolTip="기울임 · * *"
                                    Click="FormatItalic_Click"/>
                            <Button Style="{StaticResource MemoFormatTextButton}"
                                    HorizontalAlignment="Center"
                                    Foreground="{StaticResource MemoToolbarIconBrush}"
                                    ToolTip="밑줄"
                                    Click="FormatUnderline_Click">
                                <TextBlock FontFamily="Segoe UI"
                                           FontSize="17"
                                           Foreground="{StaticResource MemoToolbarIconBrush}"
                                           Text="U"
                                           TextDecorations="Underline"/>
                            </Button>
                            <Button Style="{StaticResource MemoFormatTextButton}"
                                    HorizontalAlignment="Center"
                                    ToolTip="취소선 · ~~"
                                    Click="FormatStrike_Click">
                                <TextBlock Text="T"
                                           FontFamily="Segoe UI"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MemoToolbarIconBrush}"
                                           TextDecorations="Strikethrough"/>
                            </Button>
                            <!-- 체크리스트: 둥근 사각 안에 체크만 (예시) -->
                            <Button Style="{StaticResource MemoIconButton}"
                                    HorizontalAlignment="Center"
                                    ToolTip="체크리스트 · 체크박스 줄 삽입"
                                    Foreground="{StaticResource MemoToolbarIconBrush}"
                                    Click="InsertChecklistLine_Click">
                                <Viewbox Width="22"
                                         Height="22"
                                         Stretch="Uniform">
                                    <Canvas Width="20"
                                            Height="20"
                                            SnapsToDevicePixels="True">
                                        <Rectangle Canvas.Left="2"
                                                   Canvas.Top="2"
                                                   Width="16"
                                                   Height="16"
                                                   RadiusX="3"
                                                   RadiusY="3"
                                                   Stroke="{StaticResource MemoToolbarIconBrush}"
                                                   StrokeThickness="1"
                                                   Fill="Transparent"/>
                                        <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1.25"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 6.5,10.5 L 9,13 L 13.5,7"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- 글머리: 왼쪽 세 점 + 각 줄 (예시) -->
                            <Button Style="{StaticResource MemoIconButton}"
                                    HorizontalAlignment="Center"
                                    ToolTip="글머리 · · 줄 삽입"
                                    Foreground="{StaticResource MemoToolbarIconBrush}"
                                    Click="InsertBulletLine_Click">
                                <Viewbox Width="22"
                                         Height="22"
                                         Stretch="Uniform">
                                    <Canvas Width="20"
                                            Height="18"
                                            SnapsToDevicePixels="True">
                                        <Ellipse Canvas.Left="2"
                                                 Canvas.Top="3"
                                                 Width="2.2"
                                                 Height="2.2"
                                                 Fill="{StaticResource MemoToolbarIconBrush}"/>
                                        <Rectangle Canvas.Left="6.5"
                                                   Canvas.Top="3.6"
                                                   Width="11"
                                                   Height="1.15"
                                                   Fill="{StaticResource MemoToolbarIconBrush}"
                                                   RadiusX="0.5"
                                                   RadiusY="0.5"/>
                                        <Ellipse Canvas.Left="2"
                                                 Canvas.Top="8"
                                                 Width="2.2"
                                                 Height="2.2"
                                                 Fill="{StaticResource MemoToolbarIconBrush}"/>
                                        <Rectangle Canvas.Left="6.5"
                                                   Canvas.Top="8.6"
                                                   Width="11"
                                                   Height="1.15"
                                                   Fill="{StaticResource MemoToolbarIconBrush}"
                                                   RadiusX="0.5"
                                                   RadiusY="0.5"/>
                                        <Ellipse Canvas.Left="2"
                                                 Canvas.Top="13"
                                                 Width="2.2"
                                                 Height="2.2"
                                                 Fill="{StaticResource MemoToolbarIconBrush}"/>
                                        <Rectangle Canvas.Left="6.5"
                                                   Canvas.Top="13.6"
                                                   Width="11"
                                                   Height="1.15"
                                                   Fill="{StaticResource MemoToolbarIconBrush}"
                                                   RadiusX="0.5"
                                                   RadiusY="0.5"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- 이미지: 체크와 동일 크기 둥근 사각 + 산맥 실루엣 + 우상단 점 (예시) -->
                            <Button Style="{StaticResource MemoIconButton}"
                                    HorizontalAlignment="Center"
                                    ToolTip="이미지 자리 표시 [이미지]"
                                    Foreground="{StaticResource MemoToolbarIconBrush}"
                                    Click="InsertImagePlaceholder_Click">
                                <Viewbox Width="22"
                                         Height="22"
                                         Stretch="Uniform">
                                    <Canvas Width="20"
                                            Height="20"
                                            SnapsToDevicePixels="True">
                                        <Rectangle Canvas.Left="2"
                                                   Canvas.Top="2"
                                                   Width="16"
                                                   Height="16"
                                                   RadiusX="3"
                                                   RadiusY="3"
                                                   Stroke="{StaticResource MemoToolbarIconBrush}"
                                                   StrokeThickness="1"
                                                   Fill="Transparent"/>
                                        <Ellipse Canvas.Left="13.5"
                                                 Canvas.Top="4"
                                                 Width="2.4"
                                                 Height="2.4"
                                                 Fill="{StaticResource MemoToolbarIconBrush}"/>
                                        <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 5,15.5 L 7.5,10 L 10,12.5 L 12.5,8 L 15,15.5"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Slider Style="{StaticResource MemoFooterSlider}"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="창 불투명도 · 왼쪽(투명에 가깝게) ↔ 오른쪽(완전 불투명)"
                                    Value="{Binding ElementName=RootWindow, Path=Opacity, Mode=TwoWay}"/>
                        </UniformGrid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>

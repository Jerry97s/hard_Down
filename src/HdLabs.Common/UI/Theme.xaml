<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Design system (ezLab-inspired: clean, bright, blue accent) -->
    <Color x:Key="EzBg">#F7F9FC</Color>
    <Color x:Key="EzSurface">#FFFFFF</Color>
    <Color x:Key="EzText">#0F172A</Color>
    <Color x:Key="EzMuted">#64748B</Color>
    <Color x:Key="EzAccent">#1D9BF0</Color>
    <Color x:Key="EzBorder">#E2E8F0</Color>
    <Color x:Key="EzShadow">#14000000</Color>

    <SolidColorBrush x:Key="EzBgBrush" Color="{StaticResource EzBg}" />
    <SolidColorBrush x:Key="EzSurfaceBrush" Color="{StaticResource EzSurface}" />
    <SolidColorBrush x:Key="EzTextBrush" Color="{StaticResource EzText}" />
    <SolidColorBrush x:Key="EzMutedBrush" Color="{StaticResource EzMuted}" />
    <SolidColorBrush x:Key="EzAccentBrush" Color="{StaticResource EzAccent}" />
    <SolidColorBrush x:Key="EzBorderBrush" Color="{StaticResource EzBorder}" />

    <!-- App icon (green hd icon embedded as WPF resource) -->
    <BitmapImage x:Key="HdAppIcon" UriSource="pack://application:,,,/HdLabs.Common;component/Assets/hd_icon_green.png" />

    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{StaticResource EzBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EzTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13.5" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource EzSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EzTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EzBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="{StaticResource EzSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EzBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource EzTextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource EzAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource EzAccentBrush}" />
    </Style>

    <Style x:Key="Card" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource EzSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EzBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{StaticResource EzSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EzBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</ResourceDictionary>

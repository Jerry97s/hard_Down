<Window x:Class="HdLabs.Down.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HdLabs.Down"
        mc:Ignorable="d"
        Title="{Binding Title}" Icon="{StaticResource HdAppIcon}" Height="420" Width="860" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Analyze" Command="{Binding AnalyzeCommand}" Margin="10,0,0,0"/>
                <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" FontSize="16" BorderThickness="0" />
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Status" Foreground="{StaticResource EzMutedBrush}" />
                <TextBlock Text="{Binding Status}" FontSize="14" TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
